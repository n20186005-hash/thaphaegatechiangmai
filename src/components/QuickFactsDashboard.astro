---
import { getI18n } from '../i18n/ui';
const { messages } = getI18n(Astro.url);
const q = messages.quickFactsDashboard;
const items = q.items ?? [];
---

<section id="quick-facts" class="section-padding" style="background: var(--bg-secondary);">
  <div class="max-w-6xl mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center mb-10">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold mb-3" style="color: var(--text-primary);">{q.title}</h2>
      <p class="text-base sm:text-lg leading-relaxed" style="color: var(--text-secondary);">{q.intro}</p>
    </div>

    <div class="max-w-4xl mx-auto overflow-hidden rounded-2xl border" style="background: var(--card-bg); border-color: var(--border-color); box-shadow: var(--card-shadow);">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_1.5fr_2fr] divide-y md:divide-y-0 md:divide-x" style="border-color: var(--border-color);">
        {/* Table Header (hidden on mobile, visible on md+) */}
        <div class="hidden md:contents">
          <div class="p-4 font-semibold text-sm tracking-wider uppercase" style="background: var(--bg-tertiary); color: var(--text-muted);">{q.colDimension || 'Dimension'}</div>
          <div class="p-4 font-semibold text-sm tracking-wider uppercase" style="background: var(--bg-tertiary); color: var(--text-muted);">{q.colInfo || 'Information'}</div>
          <div class="p-4 font-semibold text-sm tracking-wider uppercase" style="background: var(--bg-tertiary); color: var(--text-muted);">{q.colNotes || 'Notes'}</div>
        </div>

        {/* Table Rows */}
        {items.map((it) => (
          <div class="grid grid-cols-1 md:contents group hover:bg-black/5 transition-colors">
            <div class="p-4 md:p-5 flex items-center border-b md:border-b-0 md:border-t" style="border-color: var(--border-color);">
              <span class="font-semibold text-sm sm:text-base" style="color: var(--text-primary);">{it.label}</span>
            </div>
            <div class="p-4 md:p-5 flex items-center border-b md:border-b-0 md:border-t" style="border-color: var(--border-color);">
              <span class="text-base sm:text-lg font-medium" style="color: var(--text-primary);">{it.value}</span>
            </div>
            <div class="p-4 md:p-5 flex items-center md:border-t" style="border-color: var(--border-color);">
              <span class="text-sm leading-relaxed" style="color: var(--text-secondary);">{it.desc || it.note}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
