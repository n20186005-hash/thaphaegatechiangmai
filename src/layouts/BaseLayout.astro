---
import '../styles/global.css';
import Header from '../components/Header.astro';
import NoticeBanner from '../components/NoticeBanner.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, buildAlternates, htmlLangAttr, getI18n } from '../i18n/ui';
import { ogLocale, siteConfig } from '../config';

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const htmlLang = htmlLangAttr(lang);
const alts = buildAlternates(path);
const canonical = alts[lang] ?? alts.zh;
const { messages } = getI18n(Astro.url);
const attractionName = messages.header?.siteName ?? messages.footer?.siteName ?? messages.meta.title;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TouristAttraction',
  name: attractionName,
  description: messages.meta.description,
  url: canonical,
  image: 'https://thaphaegatechiangmai.com/gallery/tha-phae-gate-1.jpg',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Tha Phae Road, Chang Khlan Sub-district',
    addressLocality: 'Mueang Chiang Mai District',
    addressRegion: 'Chiang Mai',
    postalCode: '50200',
    addressCountry: 'TH',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 18.7883,
    longitude: 98.9926,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '00:00',
      closes: '23:59',
    },
  ],
  isAccessibleForFree: true,
  offers: [
    {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'THB',
      url: canonical,
      description: messages.meta.description,
    },
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.4',
    reviewCount: '29240',
  },
  sameAs: ['https://maps.app.goo.gl/J8vLsp9TYAQarv1k9'],
};
  const breadcrumbLd = (() => {
    const bc = messages.breadcrumb;
    return {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: bc.home, item: `${siteConfig.baseUrl}/${lang}` },
        { '@type': 'ListItem', position: 2, name: bc.region, item: `${siteConfig.baseUrl}/${lang}#overview` },
        { '@type': 'ListItem', position: 3, name: bc.city, item: `${siteConfig.baseUrl}/${lang}#transport` },
        { '@type': 'ListItem', position: 4, name: bc.current, item: canonical },
      ],
    };
  })();
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="zh" href={alts.zh} />
    <link rel="alternate" hreflang="en" href={alts.en} />
    <link rel="alternate" hreflang="th" href={alts.th} />
    <link rel="alternate" hreflang="x-default" href={alts.xDefault} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale[lang] ?? lang} />
    <meta property="og:image" content="https://thaphaegatechiangmai.com/gallery/tha-phae-gate-1.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://thaphaegatechiangmai.com/gallery/tha-phae-gate-1.jpg" />

    <meta name="google-adsense-account" content="ca-pub-XXXXXXXXXX" />
    <script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXX" crossorigin="anonymous"></script>

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)}></script>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbLd)}></script>

    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem('theme');
          if (theme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        } catch (e) {}
      })();
    </script>

    <slot name="head" />
  </head>
  <body class="min-h-screen">
    <Header />
    <NoticeBanner />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
