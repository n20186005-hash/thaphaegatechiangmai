    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href="https://thaphaegatechiangmai.com/th" />
    <title>Tha Phae Gate (ประตูท่าแพ) · Chiang Mai</title>
  </head>
  <body>
    <p>Redirecting to <a href={target}>Thai</a>…</p>
  </body>
</html>
